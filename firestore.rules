rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Super admins are a tier above admins — only they may delete member records.
    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.get('isSuperAdmin', false) == true;
    }

    match /members/{uid} {
      // PII + payment data live here, so reads are restricted to the owner and
      // admins. Cross-member views (referral tree, downline counts, commission
      // names) read the non-sensitive mirror in /publicProfiles instead.
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());

      // You may create ONLY your own record, and ONLY as a normal member.
      // (Blocks self-registering as an admin OR super-admin. Signup sets both
      //  flags false / absent, so it still works.)
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.get('isAdmin', false) == false
        && request.resource.data.get('isSuperAdmin', false) == false;

      // Admins: full access. A member editing their OWN record may only touch the
      // forced-password flag — they may NOT self-activate, change package/dates,
      // grant themselves a referral code, edit beneficiaries (signup-only; later
      // changes go through an admin request), or escalate to admin/super-admin.
      // Anything beyond that allow-list is rejected.
      allow update: if request.auth != null && (
        isAdmin()
        || (
          request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mustChangePassword'])
        )
      );

      // Only super admins may permanently delete a member record.
      allow delete: if isSuperAdmin();
    }

    match /referralCodes/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Non-sensitive mirror of members (name, city, package, status, referral
    // links) — readable by any signed-in user so the referral tree / downline /
    // commission-name lookups work without exposing PII. A member may only
    // self-create their own (forced to "pending", no referral code); admins make
    // every later change (activate / upgrade / renewal).
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow create: if isAdmin() || (
        request.auth != null
        && request.auth.uid == uid
        && request.resource.data.get('status', '') == 'pending'
        && request.resource.data.get('referralCode', null) == null
      );
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Commissions are written only when an ADMIN activates a member or approves an
    // upgrade/renewal (triggerCommissions runs in admin context), so writes are
    // admin-only. Members may still read their own. This blocks a member from
    // forging commission docs that credit themselves.
    match /commissions/{commissionId} {
      allow get: if request.auth != null
        && (resource.data.earnedBy == request.auth.uid || isAdmin());
      allow list: if request.auth != null;
      allow write: if isAdmin();
    }

    // Transactions are admin-written only (the member-facing PayMongo flow was
    // removed). Members may read their own.
    match /transactions/{transactionId} {
      allow get: if request.auth != null
        && (resource.data.memberId == request.auth.uid || isAdmin());
      allow list: if request.auth != null;
      allow write: if isAdmin();
    }

    match /claims/{claimId} {
      allow get: if request.auth != null
        && (resource.data.memberId == request.auth.uid || isAdmin());
      allow list: if request.auth != null
        && (resource.data.memberId == request.auth.uid || isAdmin());

      // Members may file ONLY their own claim, and only as "submitted".
      allow create: if request.auth != null
        && request.resource.data.memberId == request.auth.uid
        && request.resource.data.status == "submitted";

      // Only admins can move a claim through review / approve / reject / release.
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /payouts/{payoutId} {
      allow get:    if request.auth != null && (isAdmin() || resource.data.memberId == request.auth.uid);
      allow list:   if request.auth != null && (isAdmin() || resource.data.memberId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.memberId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /upgradeRequests/{requestId} {
      allow get:    if request.auth != null && (isAdmin() || resource.data.memberId == request.auth.uid);
      allow list:   if request.auth != null; // members query their own; admins list all
      // Members may request ONLY their own upgrade, and only as "pending".
      allow create: if request.auth != null
        && request.resource.data.memberId == request.auth.uid
        && request.resource.data.status == "pending";
      // Only admins approve / reject (which also applies the member upgrade).
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /renewalRequests/{requestId} {
      allow get:    if request.auth != null && (isAdmin() || resource.data.memberId == request.auth.uid);
      allow list:   if request.auth != null; // members query their own; admins list all
      // Members may request ONLY their own renewal, and only as "pending".
      allow create: if request.auth != null
        && request.resource.data.memberId == request.auth.uid
        && request.resource.data.status == "pending";
      // Only admins approve / reject (which re-activates the member).
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
