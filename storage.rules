rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Mirror the Firestore admin check so admins can read every uploaded proof.
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/members/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    function isImageUnder(maxBytes) {
      return request.resource.size < maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    // Payment receipts (signup / upgrade / renewal proof). A member writes only
    // under their own uid; the member and any admin may read them back.
    match /receipts/{uid}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null
        && request.auth.uid == uid
        && isImageUnder(5 * 1024 * 1024);
    }

    // Claim attachments — same ownership model. Allows documents (images or PDFs)
    // up to 10 MB.
    match /claims/{uid}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
